#include <iostream>
#include <fstream>
#include <sstream>
#include <string>
#include <vector>
#include <algorithm>
#include <queue>

struct CompareHeap {
    bool operator()(const pair<double, string>& a,
                    const pair<double, string>& b) const {
        return a.first < b.first;
    }
};

vector<pair<string, double>> rankTeamsHeap(
    const unordered_map<string, SchoolProfile>& profiles,
    int top_n = 10) {
    priority_queue<
        pair<double, string>,
        vector<pair<double, string>>,
        CompareHeap
    > pq;
    for (const auto& entry : profiles) {
        const string& school = entry.first;
        const SchoolProfile& p = entry.second;

        int total_volume = p.incoming_count + p.outgoing_count;
        if (total_volume < 5) continue;

        pq.push({p.success_score, school});
    }
    vector<pair<string, double>> rankings;
    while (!pq.empty() && (int)rankings.size() < top_n) {
        pair<double, string> top = pq.top();
        pq.pop();

        rankings.push_back({top.second, top.first});
    }
    return rankings;
}
